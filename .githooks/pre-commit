#!/bin/sh
# pre-commit hook: 커밋 전에 코드 품질 검사를 순차적으로 실행한다.
# 어느 단계에서든 실패하면 커밋이 즉시 차단된다. (fast-fail 전략)
#
# 실행 순서:
#   1. gofmt     - 코드 포맷 자동 수정 + 재스테이징
#   2. golangci-lint - 정적 분석 + 자동 수정 가능한 린트 이슈 수정 + 재스테이징
#   3. make arch - DDD 아키텍처 규칙 검증
#
# 이 훅은 .githooks/ 디렉토리에 저장되어 git으로 버전 관리된다.
# 활성화하려면: make setup (git config core.hooksPath .githooks 실행)

# --- 1단계: gofmt (코드 포맷 자동 수정) ---
# gofmt -w: 포맷이 맞지 않는 파일을 자동으로 수정한다.
# 수정된 파일은 git add로 스테이징 영역에 다시 추가한다.
echo "🔍 [1/3] 코드 포맷 검사 및 자동 수정 중... (gofmt)"

# 스테이징된 .go 파일만 대상으로 한다.
# git diff --cached: 스테이징 영역에 있는 변경 파일 목록
# --name-only: 파일 경로만 출력
# --diff-filter=ACM: Added(추가), Copied(복사), Modified(수정)된 파일만 (삭제된 파일 제외)
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')

if [ -n "$STAGED_GO_FILES" ]; then
    # gofmt -l: 포맷이 맞지 않는 파일 목록 확인
    UNFORMATTED=$(echo "$STAGED_GO_FILES" | xargs gofmt -l 2>/dev/null)
    if [ -n "$UNFORMATTED" ]; then
        # gofmt -w: 포맷을 자동으로 수정한다.
        echo "$UNFORMATTED" | xargs gofmt -w
        # 수정된 파일을 스테이징 영역에 다시 추가한다.
        # 이렇게 해야 커밋에 포맷 수정이 포함된다.
        echo "$UNFORMATTED" | xargs git add
        echo "   자동 수정된 파일:"
        echo "$UNFORMATTED" | while read -r file; do
            echo "   - $file"
        done
    fi
fi

echo "✅ [1/3] 코드 포맷 검사 통과"

# --- 2단계: golangci-lint (정적 분석 + 자동 수정) ---
# --fix: 자동 수정이 가능한 린트 이슈(unused import, 정렬 등)를 자동으로 고친다.
# 자동 수정이 불가능한 이슈가 남아 있으면 실패하여 커밋이 차단된다.
echo "🔍 [2/3] 린트 검사 및 자동 수정 중... (golangci-lint --fix)"

golangci-lint run --fix
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ 린트 검사에서 자동 수정 불가능한 문제가 발견되어 커밋이 차단되었습니다."
    echo "   위반 내용을 수정한 후 다시 커밋해 주세요."
    exit 1
fi

# golangci-lint --fix가 파일을 수정했을 수 있으므로, 변경된 .go 파일을 재스테이징한다.
if [ -n "$STAGED_GO_FILES" ]; then
    echo "$STAGED_GO_FILES" | xargs git add
fi

echo "✅ [2/3] 린트 검사 통과"

# --- 3단계: make arch (아키텍처 규칙 검증) ---
echo "🔍 [3/3] 아키텍처 규칙 검증 중... (make arch)"

make arch
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ 아키텍처 규칙 위반이 발견되어 커밋이 차단되었습니다."
    echo "   위반 내용을 수정한 후 다시 커밋해 주세요."
    exit 1
fi

echo "✅ [3/3] 아키텍처 규칙 검증 통과"
echo ""
echo "✅ 모든 검사 통과! 커밋을 진행합니다."
exit 0
